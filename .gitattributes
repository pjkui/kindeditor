# Keep Composer packages lean — exclude dev-only files from the dist archive.
/.github          export-ignore
/tests            export-ignore
/examples         export-ignore
/.gitattributes   export-ignore
/.gitignore       export-ignore
/phpunit.xml.dist export-ignore
/CODEBUDDY.md     export-ignore

# Normalize line endings.
*           text=auto
*.php       text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
